{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:allow-app-write-recursive",
    "fs:allow-app-read-recursive"
  ]
}
